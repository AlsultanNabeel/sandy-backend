# Sandy product backend — environment template.
# Copy to .env for local dev; set the same as Heroku config vars in prod.
# Tiered: REQUIRED boots a working API; the rest enable specific features.

# ── REQUIRED: data + auth + brain ─────────────────────────────────────────────
MONGODB_URI=
MONGODB_DB_NAME=sandy-app          # the clean product DB (NOT sany-db)
JWT_SECRET=                        # signs user tokens — empty = every token refused
OWNER_PASSWORD=                    # owner dev/app login

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=

# Azure OpenAI = the router/brain
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=

# Owner identity (tenant #1). Transitional until the clean uuid fully replaces it.
SANDY_USER_CHAT_ID=628544372
OWNER_CHAT_ID=628544372
# The owner's clean product tenant id (printed by the Phase 1 migration). Lets the
# transitional device gates (robot/room actuation) recognise the app/web owner.
OWNER_TENANT_ID=

# ── PRODUCT: real user sign-in + subscriptions ───────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
APPLE_BUNDLE_ID=
REVENUECAT_WEBHOOK_AUTH=
FRONTEND_URL=                      # CORS origin for the web client (default *)

# ── IMAGES (Azure image gen/edit) ────────────────────────────────────────────
AZURE_OPENAI_IMAGE_ENDPOINT=
AZURE_OPENAI_IMAGE_API_KEY=
AZURE_OPENAI_IMAGE_API_VERSION=2024-02-01
AZURE_OPENAI_IMAGE_DEPLOYMENT=
AZURE_OPENAI_IMAGE_EDIT_DEPLOYMENT=

# ── VOICE: Gemini Live + TTS fallbacks ───────────────────────────────────────
SANDY_LIVE_MODEL=gemini-2.5-flash-native-audio-latest
GEMINI_TTS_VOICE=Aoede
# Fallbacks (optional): Google Cloud TTS, then Azure Speech
GOOGLE_APPLICATION_CREDENTIALS=    # or GOOGLE_CREDENTIALS_JSON (inline JSON on Heroku)
GOOGLE_TTS_VOICE=ar-XA-Chirp3-HD-Sulafat
GOOGLE_TTS_LANGUAGE_CODE=ar-XA
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_VOICE=ar-LB-LaylaNeural

# ── RESEARCH / PLACES ─────────────────────────────────────────────────────────
EXA_API_KEY=
WEB_RESEARCH_PROVIDER=exa
GOOGLE_PLACES_API_KEY=

# ── ENCRYPTION (long-term + biometric memory) ────────────────────────────────
SANDY_LTM_KEY=                     # Fernet key; empty = LTM encryption disabled
SANDY_BIO_KEY=

# ── OWNER DEVICE (transitional: his robot/room only) ─────────────────────────
SANDY_MQTT_HOST=
SANDY_MQTT_PORT=
SANDY_MQTT_USER=
SANDY_MQTT_PASS=
ROBOT_WS_SECRET=                   # robot voice WebSocket auth
SANDY_WS_HMAC_KEY=
SANDY_REQUIRE_SPEAKER_AUTH=0       # 1 = verify owner voice before sensitive cmds

# ── OBSERVABILITY (optional) ──────────────────────────────────────────────────
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
GRAFANA_CLOUD_REMOTE_WRITE_URL=
GRAFANA_CLOUD_USERNAME=
GRAFANA_CLOUD_API_KEY=

# ── RUNTIME ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
USER_TIMEZONE=Africa/Cairo
APP_VERSION=
