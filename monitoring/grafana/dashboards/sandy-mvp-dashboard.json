{
  "uid": "sandy-mvp",
  "title": "Sandy Observability",
  "tags": ["sandy", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "options": [],
        "hide": 0,
        "label": "Prometheus datasource"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "LLM Health",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "failure rate"}, "properties": [{"id": "unit", "value": "percentunit"}, {"id": "custom.axisPlacement", "value": "left"}]},
          {"matcher": {"id": "byName", "options": "p95 latency"}, "properties": [{"id": "unit", "value": "s"}, {"id": "custom.axisPlacement", "value": "right"}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [
        {"refId": "A", "expr": "sum(rate(sandy_llm_completion_failure_total[5m])) / clamp_min(sum(rate(sandy_llm_completion_failure_total[5m])) + sum(rate(sandy_llm_completion_success_total[5m])), 0.001)", "legendFormat": "failure rate"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum(rate(sandy_llm_completion_seconds_bucket[5m])) by (le))", "legendFormat": "p95 latency"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Webhook Layer",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "ingress rate"}, "properties": [{"id": "unit", "value": "reqps"}, {"id": "custom.axisPlacement", "value": "left"}]},
          {"matcher": {"id": "byName", "options": "dedup ratio"}, "properties": [{"id": "unit", "value": "percentunit"}, {"id": "custom.axisPlacement", "value": "right"}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [
        {"refId": "A", "expr": "sum(rate(sandy_telegram_webhook_ingress_total[5m]))", "legendFormat": "ingress rate"},
        {"refId": "B", "expr": "sum(rate(sandy_telegram_webhook_dedup_total[5m])) / clamp_min(sum(rate(sandy_telegram_webhook_ingress_total[5m])), 0.001)", "legendFormat": "dedup ratio"}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Resume System",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [
        {"refId": "A", "expr": "sum(rate(sandy_agent_resume_wait_seconds_count[5m]))", "legendFormat": "resume waits"},
        {"refId": "B", "expr": "sum(rate(sandy_agent_resume_wait_shutdown_total[5m]))", "legendFormat": "shutdown waits"},
        {"refId": "C", "expr": "sum(rate(sandy_agent_resume_wait_resumed_total[5m]))", "legendFormat": "successful resumes"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Errors Overview",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "error rate"}, "properties": [{"id": "unit", "value": "reqps"}]},
          {"matcher": {"id": "byName", "options": "errors last hour"}, "properties": [{"id": "unit", "value": "short"}, {"id": "custom.axisPlacement", "value": "right"}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [
        {"refId": "A", "expr": "sum(rate(sandy_error_log_total[5m]))", "legendFormat": "error rate"},
        {"refId": "B", "expr": "sum(increase(sandy_error_log_total[1h]))", "legendFormat": "errors last hour"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Project-Builder — Tasks by status",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"refId": "A", "expr": "sum by (status) (rate(sandy_project_builder_task_total[5m]))", "legendFormat": "{{status}}"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Project-Builder — Tasks by type",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {"refId": "A", "expr": "sum by (task_type) (rate(sandy_project_builder_task_total[5m]))", "legendFormat": "{{task_type}}"}
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Project-Builder — Tool calls",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [
        {"refId": "A", "expr": "sum by (tool) (rate(sandy_project_builder_tool_calls_total[5m]))", "legendFormat": "{{tool}}"}
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Project-Builder — Iterations per feature (p50/p95)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.5, sum(rate(sandy_project_builder_iterations_bucket[15m])) by (le))", "legendFormat": "p50"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum(rate(sandy_project_builder_iterations_bucket[15m])) by (le))", "legendFormat": "p95"}
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Project-Builder — Tokens per run (p50/p95)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.5, sum(rate(sandy_project_builder_tokens_used_bucket[15m])) by (le))", "legendFormat": "p50"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum(rate(sandy_project_builder_tokens_used_bucket[15m])) by (le))", "legendFormat": "p95"}
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Project-Builder — Task duration (p50/p95)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.5, sum(rate(sandy_project_builder_duration_seconds_bucket[15m])) by (le))", "legendFormat": "p50"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum(rate(sandy_project_builder_duration_seconds_bucket[15m])) by (le))", "legendFormat": "p95"}
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Project-Builder — CI outcomes (last 24h)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 40},
      "targets": [
        {"refId": "A", "expr": "sum by (result) (increase(sandy_project_builder_ci_outcome_total[24h]))", "legendFormat": "{{result}}"}
      ]
    }
  ]
}
